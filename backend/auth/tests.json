{
  "tests": [
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "username": "TestUser99", "password": "test1234"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login existing user",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "username": "TestUser99", "password": "test1234"},
      "expectedStatus": 200,
      "expectedBody": {"ok": true},
      "bodyMatcher": "partial"
    },
    {
      "name": "Wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "username": "TestUser99", "password": "wrongpass"},
      "expectedStatus": 401,
      "expectedBody": {"error": "Неверный пароль"},
      "bodyMatcher": "partial"
    }
  ]
}
